<h1>Бүртгүүлэх</h1>
<form method="POST" action="/auth/register" class="form">
  <input name="full_name" placeholder="Овог нэр" required />
  <input name="email" type="email" placeholder="Email" required />
  <input name="phone" placeholder="Утас" />
  <select name="role"><option value="customer">Customer</option><option value="operator">Operator</option></select>
  <input name="password" type="password" placeholder="Нууц үг" required />
  <button type="submit">Бүртгүүлэх</button>
</form>
